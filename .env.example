# Google Civic Information API (free - https://console.cloud.google.com/)
GOOGLE_CIVIC_API_KEY=

# Open States API (free - https://open.pluralpolicy.com/accounts/profile/)
OPEN_STATES_API_KEY=

# Resend for email delivery (free tier - https://resend.com)
RESEND_API_KEY=

# Database (auto-set by Heroku Postgres addon)
DATABASE_URL=

# App origin (required by SvelteKit adapter-node on Heroku)
ORIGIN=http://localhost:5173
